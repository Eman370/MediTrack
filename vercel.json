function getPatient() { return uStore.get('patient') || accPatient(); }
function accPatient() { const a = getAccounts().find(x => x.id === CUR); return a ? a.patient : {}; }

function savePatientLocal(data) {
  uStore.set('patient', data);
  // also update accounts store
  const accs = getAccounts();
  const idx  = accs.findIndex(a => a.id === CUR);
  if (idx >= 0) { accs[idx].patient = { ...accs[idx].patient, ...data }; saveAccounts(accs); }
