/* Topbar real-time clock */
function tickClock() {
  const now = new Date();
  const h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
  const ap = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 || 12;
  const timeStr = `${pad(h12)}:${pad(m)}:${pad(s)} ${ap}`;
  const el = document.getElementById('tb-clock');
  if (el) el.textContent = timeStr;
}
tickClock(); setInterval(tickClock, 1000);

/* Offline detect */
function checkOnline() { document.getElementById('offline-bar').classList.toggle('show', !navigator.onLine); }
window.addEventListener('online', checkOnline); window.addEventListener('offline', checkOnline); checkOnline();

/* Modals */
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); }));

/* Toast */
function toast(msg, type = 'info') {
  const icons = {success:'✅',info:'ℹ️',warning:'⚠️',error:'❌'};
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.innerHTML = `<span>${icons[type]}</span><span>${msg}</span>`;
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(() => { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3200);
}

// ══════════════════════════════════════════════════════
//  DATE / TIME UTILS  (declared at top of script)
// ══════════════════════════════════════════════════════

function fmtTime(t) {
  if (!t) return '—';
  const [h, m] = t.split(':').map(Number);
  const ap = h >= 12 ? 'PM' : 'AM';
  return `${h % 12 || 12}:${pad(m)} ${ap}`;
}
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d + 'T00:00:00').toLocaleDateString('en-PH', { month: 'long', day: 'numeric', year: 'numeric' });
}
function calcAge(dob) {
  if (!dob) return '—';
  const b = new Date(dob), t = new Date();
  let a = t.getFullYear() - b.getFullYear();
  if (t.getMonth() < b.getMonth() || (t.getMonth() === b.getMonth() && t.getDate() < b.getDate())) a--;
  return a + ' yrs old';
}
function genId() { return 'MT-' + Math.floor(100000 + Math.random() * 900000); }

function defaultTimes(freq) {
  return { 1: ['08:00'], 2: ['08:00','20:00'], 3: ['08:00','14:00','20:00'], 4: ['07:00','12:00','18:00','22:00'] }[freq] || ['08:00'];
}

/* ══════════════════════════════════════════════
   DATA ACCESSORS  (declared at top of script)
══════════════════════════════════════════════ */

function addActivity(msg) {
  const log = getActivity();
  log.unshift({msg, ts: new Date().toISOString()});
  saveActivity(log.slice(0,40));
}

/* ══════════════════════════════════════════════
   TIME SCHEDULER UI
══════════════════════════════════════════════ */
let schedTimes = []; // working array while modal is open

function initTimeScheduler() {
  renderSchedChips();
  // Quick-preset button listeners
  document.querySelectorAll('.tq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const t = btn.dataset.time;
      if (schedTimes.includes(t)) {
        schedTimes = schedTimes.filter(x => x !== t);
        btn.classList.remove('applied');
      } else {
        schedTimes.push(t);
        schedTimes.sort();
        btn.classList.add('applied');
      }
      renderSchedChips();
    });
  });
}

function renderSchedChips() {
  const wrap  = document.getElementById('sched-times-wrap');
  const empty = document.getElementById('times-empty-msg');
  // reset quick-btn states
  document.querySelectorAll('.tq-btn').forEach(b => b.classList.toggle('applied', schedTimes.includes(b.dataset.time)));

  if (!schedTimes.length) {
    wrap.innerHTML = '';
    wrap.appendChild(empty);
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  wrap.innerHTML = schedTimes.map((t, i) => {
    const [h, m] = t.split(':').map(Number);
    const ap = h >= 12 ? 'PM' : 'AM';
    const h12 = h%12||12;
    const labels = ['Morning','Mid-Morning','Noon','Afternoon','Evening','Night','Bedtime'];
    const label = h < 10 ? 'Morning' : h < 12 ? 'Mid-Morning' : h === 12 ? 'Noon' : h < 17 ? 'Afternoon' : h < 20 ? 'Evening' : h < 22 ? 'Night' : 'Bedtime';
    return `<div class="sched-time-chip">
      <span class="stc-time">${h12}:${pad(m)}</span><span class="stc-ampm"> ${ap}</span>
      <span class="stc-label">${label}</span>
      <button class="stc-del" onclick="removeSchedTime('${t}')" title="Remove">×</button>
    </div>`;
  }).join('');
}

function removeSchedTime(t) {
  schedTimes = schedTimes.filter(x => x !== t);
  renderSchedChips();
}
window.removeSchedTime = removeSchedTime;

document.getElementById('add-time-btn').addEventListener('click', () => {
  const t = document.getElementById('custom-time-in').value;
  if (!t) { toast('Please select a time first.', 'warning'); return; }
  if (schedTimes.includes(t)) { toast('This time is already added.', 'info'); return; }
  schedTimes.push(t);
  schedTimes.sort();
  document.getElementById('custom-time-in').value = '';
  renderSchedChips();
  toast(`${fmtTime(t)} added!`, 'success');
});

// When frequency template changes, auto-fill times
document.getElementById('med-freq').addEventListener('change', function() {
  const v = this.value;
  if (v !== 'custom') {
    schedTimes = [...defaultTimes(parseInt(v))];
    renderSchedChips();
    toast(`Preset times applied! You can still add or remove times.`, 'info');
  }
});

/* ══════════════════════════════════════════════
   MEDICATION CRUD
══════════════════════════════════════════════ */
function openMedModal(med = null) {
  schedTimes = med ? [...(med.times || [])] : [];
  document.getElementById('med-edit-id').value         = med?.id || '';
  document.getElementById('med-modal-title').textContent = med ? 'Edit Medication' : 'Add Medication';
  document.getElementById('med-name').value             = med?.name      || '';
  document.getElementById('med-dose').value             = med?.dose      || '';
  document.getElementById('med-type').value             = med?.type      || 'Tablet';
  document.getElementById('med-freq').value             = med?.freqLabel || 'custom';
  document.getElementById('med-start').value            = med?.startDate || todayStr();
  document.getElementById('med-end').value              = med?.endDate   || '';
  document.getElementById('med-notes').value            = med?.notes     || '';
  initTimeScheduler();
  openModal('modal-med');
}

document.getElementById('open-add-med').addEventListener('click', () => openMedModal());

document.getElementById('save-med-btn').addEventListener('click', () => {
  const name = document.getElementById('med-name').value.trim();
  const dose = document.getElementById('med-dose').value.trim();
  if (!name || !dose) { toast('Medicine name and dosage are required.', 'warning'); return; }
  if (!schedTimes.length) { toast('Please add at least one scheduled time.', 'warning'); return; }

  const med = {
    name, dose,
    type:       document.getElementById('med-type').value,
    freqLabel:  document.getElementById('med-freq').value,
    times:      [...schedTimes],
    startDate:  document.getElementById('med-start').value || todayStr(),
    endDate:    document.getElementById('med-end').value   || null,
    notes:      document.getElementById('med-notes').value,
    active:     true,
    createdAt:  new Date().toISOString()
  };

  const editId = document.getElementById('med-edit-id').value;
  const meds   = getMeds();

  if (editId) {
    const idx = meds.findIndex(m => m.id == editId);
    if (idx >= 0) { med.id = parseInt(editId); meds[idx] = med; }
    toast(`${name} updated!`, 'success');
  } else {
    med.id = Date.now();
    meds.push(med);
    toast(`${name} added!`, 'success');
    addActivity(`Medication added: ${name} ${dose}`);
  }
  saveMeds(meds);
  closeModal('modal-med');
  refreshDashboard();
  renderScheduler();
  scheduleAlarms();
  updateBadge();
});

function deleteMed(id, triggerBtn) {
  const meds = getMeds();
  const med  = meds.find(m => m.id == id);
  if (!med) return;

  // Walk up from the clicked button to find the .med-item row
  const row = triggerBtn ? triggerBtn.closest('.med-item') : null;

  // If a confirm strip is already open in this row, ignore repeat clicks
  if (row && row.querySelector('.del-confirm-row')) return;

  if (row) {
    const strip = document.createElement('div');
    strip.className = 'del-confirm-row';
    strip.style.cssText = [
      'display:flex;align-items:center;gap:10px;margin-top:10px',
      'padding:8px 12px;background:rgba(176,48,48,0.08)',
      'border-radius:8px;border:1.5px solid rgba(176,48,48,0.22)',
      'animation:alertSlide .2s ease;flex-wrap:wrap'
    ].join(';');
    strip.innerHTML =
      '<span style="font-size:13px;color:#B03030;font-weight:600;flex:1">Remove <strong>'
      + med.name + '</strong>?</span>'
      + '<button style="padding:5px 16px;background:#B03030;color:#fff;border:none;'
      + 'border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:.3px"'
      + ' onclick="confirmDeleteMed(' + id + ')">Yes, Remove</button>'
      + '<button style="padding:5px 12px;background:transparent;color:var(--txt-m,#5C6E82);'
      + 'border:1.5px solid var(--bdr,rgba(60,80,110,0.2));border-radius:6px;font-size:13px;cursor:pointer"'
      + ' onclick="this.closest(\'.del-confirm-row\').remove()">Cancel</button>';
    row.appendChild(strip);
  } else {
    // Fallback if row not found — delete directly
    confirmDeleteMed(id);
  }
}
window.deleteMed = deleteMed;

function confirmDeleteMed(id) {
  const meds = getMeds();
  const med  = meds.find(m => m.id == id);
  saveMeds(meds.map(m => m.id == id ? {...m, active: false} : m));
  if (med) addActivity('Medication removed: ' + med.name);
  toast('Medication removed.', 'info');
  refreshDashboard();
  renderScheduler();
  scheduleAlarms();
  updateBadge();
}
window.confirmDeleteMed = confirmDeleteMed;

function openEditMed(id) { const med = getMeds().find(m => m.id == id); if (med) openMedModal(med); }
window.openEditMed = openEditMed;

/* ══════════════════════════════════════════════
   MARK TAKEN
══════════════════════════════════════════════ */
function markTaken(medId, time, date_, by = 'Self') {
  const logs = getLogs();
  const ex   = logs.find(l => l.medId == medId && l.date === date_ && l.scheduledTime === time);
  if (ex) { ex.status = 'taken'; ex.takenAt = new Date().toISOString(); ex.loggedBy = by; }
  else logs.push({id:Date.now(), medId, date:date_, scheduledTime:time, status:'taken', takenAt:new Date().toISOString(), loggedBy:by});
  saveLogs(logs);
  const med = getMeds().find(m => m.id == medId);
  if (med) { toast(`✅ ${med.name} marked as taken!`, 'success'); addActivity(`${med.name} (${fmtTime(time)}) marked as taken.`); }
  if (currentAlarm?.medId == medId && currentAlarm?.time === time) dismissAlarm();

  // Animate the reminder item out smoothly, then refresh
  const reminderItems = document.querySelectorAll('#reminders-list .alert-item');
  let found = false;
  reminderItems.forEach(el => {
    const btn = el.querySelector(`button[onclick*="markTaken(${medId},'${time}'"]`);
    if (btn) {
      found = true;
      el.style.transition = 'opacity 0.3s ease, transform 0.3s ease, max-height 0.35s ease, margin 0.35s ease, padding 0.35s ease';
      el.style.opacity = '0';
      el.style.transform = 'translateX(30px)';
      el.style.maxHeight = el.offsetHeight + 'px';
      setTimeout(() => {
        el.style.maxHeight = '0';
        el.style.marginBottom = '0';
        el.style.padding = '0';
      }, 280);
    }
  });

  const delay = found ? 380 : 0;
  setTimeout(() => {
    refreshDashboard(); renderReminders(); updateBadge();
  }, delay);
}
window.markTaken = markTaken;

/* ══════════════════════════════════════════════
   DASHBOARD
══════════════════════════════════════════════ */

function refreshDashboard() {
  const today = todayStr();
  const meds  = getMeds().filter(m => m.active);
  const logs  = getLogs().filter(l => l.date === today);

  let taken = 0, total = 0;
  meds.forEach(m => {
    total += m.times.length;
    m.times.forEach(t => { if (logs.find(l => l.medId == m.id && l.scheduledTime === t && l.status === 'taken')) taken++; });
  });
  const missed = getLogs().filter(l => l.status === 'missed').length;

  const _st = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  _st('st-total',   meds.length);
  _st('st-taken',   taken);
  _st('st-pending', Math.max(0, total - taken));
  _st('st-missed',  missed);

  renderTodayList(meds, logs, today);
  buildDashboardCalendar(meds);
  updateBadge();
}

function getMedClass(type) {
  if (!type) return 'mt-other';
  const t = type.toLowerCase();
  if (t.includes('tablet'))  return 'mt-tablet';
  if (t.includes('capsule')) return 'mt-capsule';
  if (t.includes('liquid') || t.includes('ml')) return 'mt-liquid';
  return 'mt-other';
}
function getMedIcon(type) {
  if (!type) return '💊';
  const t = type.toLowerCase();
  if (t.includes('tablet'))  return '💊';
  if (t.includes('capsule')) return '💉';
  if (t.includes('liquid') || t.includes('ml')) return '🧪';
  if (t.includes('inhaler')) return '💨';
  if (t.includes('injection')) return '💉';
  if (t.includes('patch'))   return '🩹';
  if (t.includes('drop'))    return '💧';
  return '💊';
}

function renderTodayList(meds, logs, today) {
  const el = document.getElementById('today-list');
  if (!meds.length) { el.innerHTML = '<div class="empty"><div class="ei">💊</div><p>No medications yet.</p></div>'; return; }
  let items = [];
  meds.forEach(med => med.times.forEach(t => {
    const log   = logs.find(l => l.medId == med.id && l.scheduledTime === t);
    items.push({med, t, taken: log?.status === 'taken', past: t < nowTime()});
  }));
  items.sort((a,b) => a.t.localeCompare(b.t));
  el.innerHTML = items.slice(0,8).map(({med, t, taken, past}) => {
    const sCls = taken ? 's-taken' : past ? 's-missed' : 's-upcoming';
    const badge = taken ? '<span class="badge b-sage">✓ Taken</span>' : past ? '<span class="badge b-rose">Overdue</span>' : `<span class="badge b-amber">${fmtTime(t)}</span>`;
    return `<div class="med-item ${sCls}">
      <div class="med-icon ${getMedClass(med.type)}">${getMedIcon(med.type)}</div>
      <div class="med-det"><div class="med-name">${med.name}</div><div class="med-meta">${med.dose} · ${med.type}</div></div>
      ${badge}
      ${!taken ? `<button class="check-btn" onclick="markTaken(${med.id},'${t}','${today}')" title="Mark taken">✓</button>` : '<div class="check-btn done">✓</div>'}
    </div>`;
  }).join('');
}

/* ══════════════════════════════════════════════
   DASHBOARD CALENDAR
══════════════════════════════════════════════ */
let calYear = new Date().getFullYear();
let calMonth = new Date().getMonth();

function buildDashboardCalendar(meds) {
  renderCalendar(meds, calYear, calMonth);
  document.getElementById('cal-prev').onclick = () => {
    calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar(getMeds().filter(m => m.active), calYear, calMonth);
  };
  document.getElementById('cal-next').onclick = () => {
    calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar(getMeds().filter(m => m.active), calYear, calMonth);
  };
}

function renderCalendar(meds, year, month) {
  const today = new Date();
  const todayIso = todayStr();
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-month-label').textContent = `${monthNames[month]} ${year}`;

  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const prevMonthDays = new Date(year, month, 0).getDate();
  const logs = getLogs();

  const grid = document.getElementById('cal-grid');
  let html = '';

  // Previous month trailing days
  for (let i = firstDay - 1; i >= 0; i--) {
    html += `<div class="cal-day other-month">${prevMonthDays - i}</div>`;
  }

  // Current month days
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = `${year}-${pad(month + 1)}-${pad(d)}`;
    const isToday = ds === todayIso;
    const dayLogs = logs.filter(l => l.date === ds);
    let cls = '';
    let hasMeds = false;

    if (meds.length > 0) {
      let tot = 0, tak = 0;
      meds.forEach(med => {
        tot += med.times.length;
        tak += dayLogs.filter(l => l.medId == med.id && l.status === 'taken').length;
      });
      if (tot > 0) {
        hasMeds = true;
        const pct = tak / tot;
        if (pct >= 1) cls = 'all-taken';
        else if (pct > 0) cls = 'partial';
        else if (ds < todayIso) cls = 'has-missed';
        else cls = 'has-meds';
      }
    }

    html += `<div class="cal-day ${isToday ? 'today' : ''} ${cls}">${d}</div>`;
  }

  // Next month leading days
  const totalCells = firstDay + daysInMonth;
  const remaining = (7 - (totalCells % 7)) % 7;
  for (let i = 1; i <= remaining; i++) {
    html += `<div class="cal-day other-month">${i}</div>`;
  }

  grid.innerHTML = html;
}

/* ══════════════════════════════════════════════
   SCHEDULER
══════════════════════════════════════════════ */
function renderScheduler() {
  renderMedList(getMeds().filter(m => m.active), 'sched-active');
  renderMedList(getMeds(), 'sched-all');
}

function renderMedList(meds, elId) {
  const el   = document.getElementById(elId);
  const today = todayStr();
  const logs  = getLogs().filter(l => l.date === today);
  if (!meds.length) { el.innerHTML = '<div class="empty"><div class="ei">💊</div><p>No medications here.</p></div>'; return; }
  el.innerHTML = meds.map(med => {
    const chips = med.times.map(t => {
      const log   = logs.find(l => l.medId == med.id && l.scheduledTime === t);
      const taken = log?.status === 'taken';
      const now   = nowTime();
      const cls   = taken ? 'taken' : t >= now ? 'upcoming' : 'overdue';
      return '<div class="tch ' + cls + '">' + (taken?'✓':'⏰') + ' ' + fmtTime(t) + '</div>';
    }).join('');
    const inact = !med.active ? '<span class="badge b-muted">Archived</span>' : '';
    const delBtn = med.active ? '<button class="btn btn-danger btn-sm btn-icon" onclick="deleteMed(' + med.id + ',this)" title="Remove">🗑️</button>' : '';
    return '<div class="med-item ' + (med.active?'s-active':'') + '">'
      + '<div class="med-icon ' + getMedClass(med.type) + '">' + getMedIcon(med.type) + '</div>'
      + '<div class="med-det">'
      + '<div class="med-name">' + med.name + ' <span style="font-weight:400;color:var(--txt-s);font-size:13px">' + med.dose + '</span> ' + inact + '</div>'
      + '<div class="med-meta">' + med.type + ' · ' + (med.notes ? med.notes.slice(0,50)+'…' : 'No special instructions') + '</div>'
      + '<div class="med-times">' + chips + '</div>'
      + '</div>'
      + '<div class="med-acts">'
      + '<button class="btn btn-ghost btn-sm btn-icon" onclick="openEditMed(' + med.id + ')" title="Edit">✏️</button>'
      + delBtn
      + '</div>'
      + '</div>';
  }).join('');
}

// Tabs
document.querySelectorAll('.tab-item').forEach(tab => {
  tab.addEventListener('click', () => {
    const tbar = tab.closest('.tab-bar');
    tbar.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const id = tab.dataset.tab;
    // Try class-based first, fall back to direct ID lookup for scheduler tabs
    const byClass = document.querySelectorAll('.tab-content');
    if (byClass.length > 0) {
      byClass.forEach(c => c.style.display = c.id === id ? 'block' : 'none');
    } else {
      // Scheduler tabs: tab-active and tab-all
      ['tab-active', 'tab-all'].forEach(tid => {
        const el = document.getElementById(tid);
        if (el) el.style.display = tid === id ? 'block' : 'none';
      });
    }
  });
});

// ══════════════════════════════════════════════════════
//  REMINDERS
// ══════════════════════════════════════════════════════
function renderReminders() {
  const el    = document.getElementById('reminders-list');
  const meds  = getMeds().filter(m => m.active);
  const today = todayStr();
  const logs  = getLogs().filter(l => l.date === today);
  const now   = nowTime();

  if (!meds.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">🔔</div><p>Add medications to see reminders here.</p></div>'; return; }

  let items = [];
  meds.forEach(med => {
    med.times.forEach(t => {
      const log   = logs.find(l => l.medId == med.id && l.scheduledTime === t);
      const taken = log?.status === 'taken';
      // Only show items that are NOT yet taken
      if (!taken) {
        items.push({ med, t, taken, past: t < now });
      }
    });
  });
  items.sort((a, b) => a.t.localeCompare(b.t));

  if (!items.length) {
    el.innerHTML = '<div class="empty"><div class="ei">✅</div><p>All medications taken for now! Great job.</p></div>';
    return;
  }

  el.innerHTML = items.map(({ med, t, past }) => {
    const cls  = past ? 'al-warn' : 'al-info';
    const icon = past ? '⚠️' : '⏰';
    const lbl  = past ? 'Overdue' : 'Upcoming';
    return `
    <div class="alert-item ${cls}">
      <div class="al-icon">${icon}</div>
      <div class="al-body">
        <div class="al-title">${med.name} — ${med.dose}</div>
        <div class="al-sub">${med.type} · ${lbl}</div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <div class="al-time">${fmtTime(t)}</div>
        <button class="btn btn-primary btn-sm" onclick="markTaken(${med.id},'${t}','${today}')">✓ Taken</button>
      </div>
    </div>`;
  }).join('');
}

function updateBadge() {
  const now   = nowTime();
  const today = todayStr();
  const logs  = getLogs().filter(l => l.date === today);
  let pending = 0;
  getMeds().filter(m => m.active).forEach(med => {
    med.times.forEach(t => {
      if (t <= now) {
        const log = logs.find(l => l.medId == med.id && l.scheduledTime === t);
        if (!log || log.status !== 'taken') pending++;
      }
    });
  });
  const badge = document.getElementById('nav-badge');
  const pip   = document.getElementById('notif-pip');
  if (badge) { badge.textContent = pending; badge.classList.toggle('show', pending > 0); }
  if (pip)   { pip.textContent   = pending; pip.classList.toggle('show', pending > 0); }
}

//=======================================================
  //ALARM
  //=======================================================

function scheduleAlarms() {
  Object.values(alarmTimers).forEach(clearTimeout);
  alarmTimers = {};
  const meds = getMeds().filter(m => m.active);
  meds.forEach(med => med.times.forEach(t => scheduleOne(med, t)));
}

function scheduleOne(med, t) {
  const now    = new Date();
  const target = new Date();
  const [h, m] = t.split(':').map(Number);
  target.setHours(h, m, 0, 0);
  let diff = target - now;
  if (diff < 0) diff += 86400000;
  const key = `${med.id}_${t}`;
  alarmTimers[key] = setTimeout(async () => {
    const log = getLogs().find(l => l.medId == med.id && l.date === todayStr() && l.scheduledTime === t);
    if (!log) ringAlarm(med, t);
  }, diff);
}

/* ══════════════════════════════════════════════
   ALARM SOUND (Web Audio API — no external file needed)
══════════════════════════════════════════════ */
let alarmAudioCtx = null;
let alarmNodes = [];

function startAlarmSound() {
  try {
    alarmAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
    function beepCycle() {
      if (!alarmAudioCtx) return;
      const freqs = [880, 1100, 880, 1100];
      let delay = 0;
      freqs.forEach(freq => {
        const osc = alarmAudioCtx.createOscillator();
        const gain = alarmAudioCtx.createGain();
        osc.connect(gain); gain.connect(alarmAudioCtx.destination);
        osc.frequency.value = freq;
        osc.type = 'sine';
        const t = alarmAudioCtx.currentTime + delay;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.35, t + 0.02);
        gain.gain.setValueAtTime(0.35, t + 0.18);
        gain.gain.linearRampToValueAtTime(0, t + 0.22);
        osc.start(t); osc.stop(t + 0.25);
        alarmNodes.push(osc);
        delay += 0.28;
      });
      // Repeat every 2 seconds
      alarmSoundTimer = setTimeout(beepCycle, 2000);
    }
    beepCycle();
  } catch(e) { console.warn('Audio context error:', e); }
}

function stopAlarmSound() {
  clearTimeout(alarmSoundTimer);
  if (alarmAudioCtx) {
    try { alarmAudioCtx.close(); } catch(e) {}
    alarmAudioCtx = null;
  }
  alarmNodes = [];
}

let alarmSoundTimer = null;
let currentAlarm = null;
let alarmTimers = {};

function ringAlarm(med, t) {
  currentAlarm = { medId: med.id, time: t };
  document.getElementById('alarm-med-name').textContent = med.name;
  document.getElementById('alarm-dose-text').textContent = med.dose + ' — ' + fmtTime(t);
  document.getElementById('alarm-note-text').textContent = med.notes || 'Take as prescribed.';
  document.getElementById('alarm-overlay').classList.add('ringing');

  startAlarmSound();

  if (Notification.permission === 'granted') {
    new Notification('💊 MediTrack Reminder', { body: `Time to take ${med.name} — ${med.dose}` });
  }
}

function dismissAlarm() {
  document.getElementById('alarm-overlay').classList.remove('ringing');
  stopAlarmSound();
  currentAlarm = null;
}

document.getElementById('alarm-taken-btn').addEventListener('click', () => {
  if (!currentAlarm) return;
  markTaken(currentAlarm.medId, currentAlarm.time, todayStr());
  dismissAlarm();
});

document.getElementById('alarm-snooze-btn').addEventListener('click', () => {
  if (!currentAlarm) { dismissAlarm(); return; }
  const saved = { ...currentAlarm };
  dismissAlarm();
  toast('Snoozed for 30 minutes.', 'warning');
  setTimeout(() => {
    const med = getMeds().find(m => m.id == saved.medId);
    if (med) ringAlarm(med, saved.time);
  }, 30 * 60 * 1000);
});

document.getElementById('test-alarm-btn').addEventListener('click', () => {
  const meds = getMeds().filter(m => m.active);
  if (!meds.length) { toast('Add a medication first to test the alarm.', 'warning'); return; }
  ringAlarm(meds[0], meds[0].times[0]);
});

// Periodic check (every minute)
setInterval(() => {
  const now   = nowTime();
  const today = todayStr();
  getMeds().filter(m => m.active).forEach(med => {
    med.times.forEach(t => {
      if (t <= now) {
        const log = getLogs().find(l => l.medId == med.id && l.date === today && l.scheduledTime === t);
        if (!log || log.status !== 'taken') {
          const [h, m2] = t.split(':').map(Number);
          const tDate = new Date(); tDate.setHours(h, m2, 0, 0);
          
          const diffMinutes = Math.floor((new Date() - tDate) / 60000);
          
          if (diffMinutes >= 0 && diffMinutes % 30 === 0 && !document.getElementById('alarm-overlay').classList.contains('ringing')) {
            ringAlarm(med, t);
          }
        }
      }
    });
  });
  updateBadge();
}, 60000);

/* ══════════════════════════════════════════════
   HISTORY
══════════════════════════════════════════════ */
function renderLog(filter = '') {
  const logs = getLogs()
    .filter(l => !filter || getMeds().find(m => m.id == l.medId && m.name.toLowerCase().includes(filter.toLowerCase())))
    .sort((a,b) => (b.date+b.scheduledTime).localeCompare(a.date+a.scheduledTime))
    .slice(0, 300);
  const tbody = document.getElementById('log-tbody');
  if (!logs.length) { tbody.innerHTML = '<tr><td colspan="6"><div class="empty" style="padding:28px"><div class="ei">📋</div><p>No history yet.</p></div></td></tr>'; return; }
  const meds = getMeds();
  tbody.innerHTML = logs.map(l => {
    const med   = meds.find(m => m.id == l.medId) || {name:'Unknown',dose:'—'};
    const badge = l.status === 'taken' ? '<span class="badge b-sage">✅ Taken</span>' : '<span class="badge b-rose">⚠️ Missed</span>';
    const ta    = l.takenAt ? new Date(l.takenAt).toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'}) : '—';
    return `<tr><td><strong>${med.name}</strong></td><td>${med.dose}</td><td>${fmtTime(l.scheduledTime)} · ${fmtDate(l.date)}</td><td>${ta}</td><td>${badge}</td><td>${l.loggedBy||'Self'}</td></tr>`;
  }).join('');
}

document.getElementById('log-search').addEventListener('input', e => renderLog(e.target.value));
document.getElementById('export-csv').addEventListener('click', () => {
  const meds = getMeds();
  let csv = 'Date,Medicine,Dose,Scheduled,Taken At,Status,Logged By\n';
  getLogs().sort((a,b)=>b.date.localeCompare(a.date)).forEach(l => {
    const med = meds.find(m=>m.id==l.medId)||{name:'Unknown',dose:'—'};
    csv += `${l.date},"${med.name}","${med.dose}",${l.scheduledTime},${l.takenAt||''},${l.status},${l.loggedBy||'Self'}\n`;
  });
  dlFile('meditrack_log.csv', csv, 'text/csv');
  toast('Log exported!', 'success');
});

/* ══════════════════════════════════════════════
   PATIENT PROFILE
══════════════════════════════════════════════ */
function renderPatientID() {
  const pt   = getPatient();
  const full = `${pt.firstName||''} ${pt.lastName||''}`.trim();
  const init = ((pt.firstName||'P')[0]+(pt.lastName||'')[0]).toUpperCase();
  const _pid = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  _pid('pid-av',     init);
  _pid('pid-name',   full || '—');
  _pid('pid-idnum',  `ID: ${pt.idNumber||'—'}`);
  _pid('pid-age',    calcAge(pt.dob));
  _pid('pid-blood',  pt.blood || '—');
  _pid('pid-dob',    fmtDate(pt.dob));
  _pid('pid-cond',   pt.condition  || '—');
  _pid('pid-allerg', pt.allergies  || '—');
  _pid('pid-ins',    pt.insurance  || '—');
  _pid('pid-addr',   pt.address    || '—');
  _pid('pid-cg',     pt.caregiverName ? `${pt.caregiverName} (${pt.caregiverRel||'Caregiver'})` : '—');
  document.getElementById('pid-capbadge').innerHTML = pt.capMode === 'incapable'
    ? '<span class="badge b-amber">🤝 Assisted</span>'
    : '<span class="badge b-sage">✅ Self-managed</span>';
  const nd = document.getElementById('notes-disp'); if (nd) nd.textContent = pt.notes || 'No notes yet.';
  renderContacts();
  updateSidebar();
}

document.getElementById('edit-pt-btn').addEventListener('click', () => {
  const pt = getPatient();
  document.getElementById('pt-fname').value  = pt.firstName  || '';
  document.getElementById('pt-lname').value  = pt.lastName   || '';
  document.getElementById('pt-dob').value    = pt.dob        || '';
  document.getElementById('pt-blood').value  = pt.blood      || '';
  document.getElementById('pt-cond').value   = pt.condition  || '';
  document.getElementById('pt-allerg').value = pt.allergies  || '';
  document.getElementById('pt-ins').value    = pt.insurance  || '';
  document.getElementById('pt-addr').value   = pt.address    || '';
  document.getElementById('pt-cgname').value = pt.caregiverName || '';
  document.getElementById('pt-cgrel').value  = pt.caregiverRel  || '';
  openModal('modal-patient');
});

document.getElementById('save-pt-btn').addEventListener('click', () => {
  const fn = document.getElementById('pt-fname').value.trim();
  if (!fn) { toast('First name is required.', 'warning'); return; }
  const pt = getPatient();
  savePatientLocal({...pt, firstName:fn, lastName:document.getElementById('pt-lname').value.trim(),
    dob:document.getElementById('pt-dob').value, blood:document.getElementById('pt-blood').value,
    condition:document.getElementById('pt-cond').value, allergies:document.getElementById('pt-allerg').value,
    insurance:document.getElementById('pt-ins').value, address:document.getElementById('pt-addr').value,
    caregiverName:document.getElementById('pt-cgname').value.trim(),
    caregiverRel:document.getElementById('pt-cgrel').value
  });
  toast('Profile saved!', 'success');
  closeModal('modal-patient');
  renderPatientID();
});

document.getElementById('edit-notes-btn').addEventListener('click', () => {
  document.getElementById('notes-input').value = getPatient().notes || '';
  openModal('modal-notes');
});
document.getElementById('save-notes-btn').addEventListener('click', () => {
  const notes = document.getElementById('notes-input').value;
  savePatientLocal({...getPatient(), notes});
  document.getElementById('notes-disp').textContent = notes || 'No notes yet.';
  closeModal('modal-notes');
  toast('Notes saved!', 'success');
});

/* Emergency contacts */
document.getElementById('add-ec-btn').addEventListener('click', () => {
  document.getElementById('ec-name').value = ''; document.getElementById('ec-phone').value = '';
  openModal('modal-ec');
});
document.getElementById('save-ec-btn').addEventListener('click', () => {
  const name = document.getElementById('ec-name').value.trim(), phone = document.getElementById('ec-phone').value.trim();
  if (!name||!phone) { toast('Name and phone required.', 'warning'); return; }
  const c = getContacts(); c.push({id:Date.now(),name,phone,relationship:document.getElementById('ec-rel').value});
  saveContacts(c); toast('Contact added!', 'success'); closeModal('modal-ec'); renderContacts();
});
function renderContacts() {
  const el = document.getElementById('ec-list');
  const c  = getContacts();
  if (!c.length) { el.innerHTML = '<div class="empty" style="padding:16px 0"><div class="ei">👤</div><p>No contacts yet.</p></div>'; return; }
  const colors = ['var(--sage)','var(--sky)','var(--amber)','var(--rose)'];
  el.innerHTML = c.map((x,i) => `<div class="ec-row">
    <div class="ec-av" style="background:${colors[i%4]}22;color:${colors[i%4]}">${x.name[0].toUpperCase()}</div>
    <div class="ec-info"><div class="ec-name">${x.name}</div><div class="ec-meta">${x.relationship}</div></div>
    <div class="ec-phone">${x.phone}</div>
    <button class="btn btn-danger btn-sm btn-icon" onclick="delContact(${x.id})" style="margin-left:8px">🗑️</button>
  </div>`).join('');
}
function delContact(id) { saveContacts(getContacts().filter(c=>c.id!=id)); toast('Removed.','info'); renderContacts(); }
window.delContact = delContact;

/* ══════════════════════════════════════════════
   FAMILY PORTAL
══════════════════════════════════════════════ */
document.getElementById('add-member-btn').addEventListener('click', () => {
  document.getElementById('fm-name').value=''; document.getElementById('fm-phone').value='';
  openModal('modal-member');
});
document.getElementById('save-member-btn').addEventListener('click', () => {
  const name = document.getElementById('fm-name').value.trim();
  if (!name) { toast('Name required.','warning'); return; }
  const m = getMembers();
  m.push({id:Date.now(),name,relationship:document.getElementById('fm-rel').value,phone:document.getElementById('fm-phone').value,access:document.getElementById('fm-access').value,addedAt:new Date().toISOString()});
  saveMembers(m); addActivity(`Family member added: ${name}`); toast('Member added!','success'); closeModal('modal-member'); renderPortal();
});
function renderPortal() {
  const m = getMembers();
  const el = document.getElementById('member-list');
  if (!m.length) { el.innerHTML = '<div class="empty"><div class="ei">👥</div><p>No members yet.</p></div>'; }
  else {
    const colors=['var(--sage)','var(--sky)','var(--amber)','var(--rose)'];
    el.innerHTML = m.map((x,i)=>`<div class="member-card">
      <div class="mem-av" style="background:${colors[i%4]}22;color:${colors[i%4]}">${x.name[0].toUpperCase()}</div>
      <div style="flex:1"><div class="mem-name">${x.name}</div><div class="mem-sub">${x.relationship} · ${x.access}</div><div style="font-size:12px;color:var(--txt-muted)">● Offline</div></div>
      <button class="btn btn-danger btn-sm btn-icon" onclick="delMember(${x.id})">🗑️</button>
    </div>`).join('');
  }
  // Summary
  const today = todayStr(), meds = getMeds().filter(m=>m.active), logs = getLogs().filter(l=>l.date===today), now=nowTime();
  let tot=0,tak=0;
  meds.forEach(med=>med.times.forEach(t=>{if(t<=now){tot++;if(logs.find(l=>l.medId==med.id&&l.scheduledTime===t&&l.status==='taken'))tak++;}}));
  const pct=tot>0?Math.round((tak/tot)*100):0;
  const ppct = document.getElementById('portal-pct'); if (ppct) ppct.textContent=`${pct}% (${tak}/${tot} doses)`;
  const bars=document.getElementById('portal-bars');
  bars.innerHTML=meds.slice(0,5).map(med=>{
    const mt=logs.filter(l=>l.medId==med.id&&l.status==='taken').length;
    const pctM=Math.round((mt/med.times.length)*100);
    const cls=pctM>=100?'pf-sage':pctM>=50?'pf-sky':'pf-amber';
    return `<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px"><span style="font-weight:600;color:var(--txt-h)">${med.name}</span><span style="color:var(--txt-s)">${mt}/${med.times.length}</span></div><div class="progress-track"><div class="progress-fill ${cls}" style="width:${pctM}%"></div></div></div>`;
  }).join('');
  // Activity feed
  const feed = document.getElementById('activity-feed');
  const acts = getActivity();
  if (acts.length) {
    feed.innerHTML = acts.slice(0,10).map(a=>`<div class="alert-item al-info" style="margin-bottom:10px">
      <div class="al-icon">📌</div>
      <div class="al-body"><div class="al-title">${a.msg}</div></div>
      <div class="al-time">${new Date(a.ts).toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'})}</div>
    </div>`).join('');
  }
}
function delMember(id){saveMembers(getMembers().filter(m=>m.id!=id));toast('Removed.','info');renderPortal();}
window.delMember=delMember;

/* ══════════════════════════════════════════════
   SETTINGS
══════════════════════════════════════════════ */
function initToggles() {
  const s = uStore.get('settings') || {};
  document.querySelectorAll('.toggle').forEach(t => {
    const k = t.dataset.key;
    if (k && s[k] === '0') t.classList.remove('on');
    t.addEventListener('click', () => {
      t.classList.toggle('on');
      const st = uStore.get('settings') || {};
      st[k] = t.classList.contains('on') ? '1' : '0';
      uStore.set('settings', st);
    });
  });
}

document.getElementById('clear-log-btn').addEventListener('click', () => {
  if (!confirm("Clear today's log?")) return;
  saveLogs(getLogs().filter(l=>l.date!==todayStr()));
  toast("Today's log cleared.",'info'); refreshDashboard();
});
document.getElementById('export-all-btn').addEventListener('click', () => {
  dlFile('meditrack_backup.json', JSON.stringify({patient:getPatient(),meds:getMeds(),logs:getLogs(),contacts:getContacts(),members:getMembers(),exported:new Date().toISOString()},null,2),'application/json');
  toast('Backup exported!','success');
});
document.getElementById('logout-btn').addEventListener('click', () => {
  if (!confirm('Switch account?')) return;
  gStore.del('session');
  location.reload();
});

/* ══════════════════════════════════════════════
   UTILS
══════════════════════════════════════════════ */
function dlFile(name, content, type) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content],{type}));
  a.download = name; a.click();
}

/* ══════════════════════════════════════════════
   INIT
══════════════════════════════════════════════ */
(function init() {
  const sid = gStore.get('session');
  if (sid && getAccounts().find(a => a.id === sid)) {
    CUR = sid;
    launchApp();
  } else {
    renderSavedAccounts();
  }
})();

// ══════════════════════════════════════════════════════
// DARK MODE
// ══════════════════════════════════════════════════════
function applyDark(on) {
  document.documentElement.setAttribute('data-theme', on ? 'dark' : 'light');
  const btn = document.getElementById('dark-toggle');
  if (btn) btn.textContent = on ? '☀️' : '🌙';
  const toggle = document.getElementById('dark-mode-toggle');
  if (toggle) toggle.classList.toggle('on', on);
}
function toggleDark() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  applyDark(!isDark);
  const s = gStore.get('settings') || {};
  s.darkmode = isDark ? '0' : '1';
  gStore.set('settings', s);
}
// Load saved dark mode preference
(function() {
  const s = gStore.get('settings') || {};
  if (s.darkmode === '1') applyDark(true);
})();



