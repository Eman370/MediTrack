const TITLES = { dashboard:'Dashboard','patient-id':'Patient Profile',scheduler:'Med Scheduler',reminders:'Reminders',history:'History Log',portal:'Family Portal',settings:'Settings' };

document.querySelectorAll('.nav-item').forEach(item => item.addEventListener('click', () => navigate(item.dataset.page)));
