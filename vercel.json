<!-- TOAST -->
<div id="toast-wrap"></div>

<!-- CHART.JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
'use strict';
/* ══════════════════════════════════════════════
   STORAGE  — namespaced, per-user
══════════════════════════════════════════════ */
let CUR = null; // current account id

const gStore = {
  get: k      => { try { return JSON.parse(localStorage.getItem('mt_g_' + k)); } catch { return null; } },
  set: (k, v) => localStorage.setItem('mt_g_' + k, JSON.stringify(v)),
  del: k      => localStorage.removeItem('mt_g_' + k)
};

const uStore = {
  get: k      => { try { return JSON.parse(localStorage.getItem(`mt_u${CUR}_` + k)); } catch { return null; } },
  set: (k, v) => localStorage.setItem(`mt_u${CUR}_` + k, JSON.stringify(v)),
  del: k      => localStorage.removeItem(`mt_u${CUR}_` + k)
};

// ── DATE / TIME UTILS (must be first — used everywhere) ──
function pad(n) { return String(n).padStart(2, '0'); }
function todayStr() { return new Date().toISOString().slice(0, 10); }
function nowTime() { const d = new Date(); return pad(d.getHours()) + ':' + pad(d.getMinutes()); }

// ── DATA ACCESSORS (must be before any render calls) ──
function getMeds()     { return uStore.get('meds')     || []; }
function saveMeds(arr)  { uStore.set('meds', arr); }
function getLogs()     { return uStore.get('logs')     || []; }
function saveLogs(arr)  { uStore.set('logs', arr); }
function getContacts()  { return uStore.get('contacts') || []; }
function saveContacts(arr){ uStore.set('contacts', arr); }
function getMembers()   { return uStore.get('members')  || []; }
function saveMembers(arr) { uStore.set('members', arr); }
function getActivity()  { return uStore.get('activity') || []; }
function saveActivity(arr){ uStore.set('activity', arr); }

/* ══════════════════════════════════════════════
   ACCOUNTS  (global store)
══════════════════════════════════════════════ */
function getAccounts()     { return gStore.get('accounts') || []; }
function saveAccounts(arr) { gStore.set('accounts', arr); }

function findAccount(username) {
  return getAccounts().find(a => a.username.toLowerCase() === username.toLowerCase().trim());
}

/* ══════════════════════════════════════════════
   AUTH STATE
══════════════════════════════════════════════ */
let suMode = null;   // 'patient'|'caregiver'
let suCap  = null;   // 'capable'|'incapable'

/* ── Tab switch ── */
function switchAuthTab(tab) {
  document.getElementById('panel-login').classList.toggle('active', tab === 'login');
  document.getElementById('panel-signup').classList.toggle('active', tab === 'signup');
  document.getElementById('tab-login').classList.toggle('active', tab === 'login');
  document.getElementById('tab-signup').classList.toggle('active', tab === 'signup');
  if (tab === 'login') renderSavedAccounts();
}

/* ── Saved accounts on login panel ── */
function renderSavedAccounts() {
  const accs = getAccounts();
  const el   = document.getElementById('saved-accounts');
  const divider = document.getElementById('login-divider');
  if (!accs.length) { el.innerHTML = ''; divider.style.display = 'none'; return; }
  divider.style.display = 'block';
  const colors = ['var(--sage)', 'var(--sky)', 'var(--amber)', 'var(--rose)'];
  el.innerHTML = accs.map((a, i) => `
    <div class="account-item" onclick="quickLogin(${a.id})">
      <div class="acc-av" style="background:${colors[i%4]}">${(a.patient.firstName||'P')[0].toUpperCase()}</div>
      <div class="acc-info">
        <div class="acc-name">${a.patient.firstName} ${a.patient.lastName||''}</div>
        <div class="acc-meta">${a.patient.setupMode === 'caregiver' ? '🧑‍⚕️ Caregiver account' : '🧓 Patient account'} · @${a.username}</div>
      </div>
      <div class="acc-arrow">→</div>
    </div>`).join('');
}

/* Quick-login by clicking saved account tile (still asks PIN) */
function quickLogin(id) {
  const acc = getAccounts().find(a => a.id === id);
  if (!acc) return;
  document.getElementById('login-username').value = acc.username;
  document.getElementById('login-pin').focus();
  toast(`Hello, ${acc.patient.firstName}! Enter your PIN to continue.`, 'info');
}

/* ── Full login ── */
function doLogin() {
  const username = document.getElementById('login-username').value.trim();
  const pin      = document.getElementById('login-pin').value;
  hideErr(['login-err', 'pin-err']);

  if (!username) { showErr('login-err'); return; }
  const acc = findAccount(username);
  if (!acc) { showErr('login-err'); return; }
  if (acc.pin !== pin) { showErr('pin-err'); return; }

  CUR = acc.id;
  gStore.set('session', CUR);
  launchApp();
}

/* ── Sign-up step navigation ── */
function suGoStep(n) {
  // validate before moving forward
  if (n === 2 && !suMode) { toast('Please select who is setting up.', 'warning'); return; }
  if (n === 2 && suCap === null) { toast('Please select patient capability.', 'warning'); return; }
  if (n === 3) {
    const fn = document.getElementById('su-fname').value.trim();
    const ln = document.getElementById('su-lname').value.trim();
    if (!fn || !ln) { toast('Please enter first and last name.', 'warning'); return; }
    if (suMode === 'caregiver' && !document.getElementById('su-cg-name').value.trim()) {
      toast('Please enter the caregiver name.', 'warning'); return;
    }
  }

  document.querySelectorAll('.signup-step').forEach((s, i) => s.classList.toggle('active', i === n));
  document.querySelectorAll('.s-dot').forEach((d, i) => {
    d.classList.toggle('active', i === n);
    d.classList.toggle('done', i < n);
  });

  if (n === 1) {
    document.getElementById('cap-title').textContent =
      suMode === 'patient' ? 'Can you use this app independently?' : 'Can the patient use this app independently?';
  }
  if (n === 2) {
    document.getElementById('caregiver-fields').style.display = (suMode === 'caregiver' || suCap === 'incapable') ? 'block' : 'none';
    document.getElementById('step2-desc').textContent =
      suMode === 'caregiver' ? 'Enter the patient\'s details and your own information as caregiver.' : 'Enter your basic details as the patient.';
  }
}

function selectMode(m) {
  suMode = m;
  document.getElementById('mc-patient').classList.toggle('sel', m === 'patient');
  document.getElementById('mc-caregiver').classList.toggle('sel', m === 'caregiver');
  document.getElementById('su-0-next').disabled = false;
}

function selectCap(c) {
  suCap = c;
  document.getElementById('cc-capable').classList.toggle('sel', c === 'capable');
  document.getElementById('cc-incapable').classList.toggle('sel', c === 'incapable');
  document.getElementById('su-1-next').disabled = false;
}

function finishSignup() {
  const username = document.getElementById('su-username').value.trim();
  const pin      = document.getElementById('su-pin').value;
  const pin2     = document.getElementById('su-pin2').value;
  hideErr(['uname-err', 'pin2-err']);

  if (!username) { toast('Please enter a username.', 'warning'); return; }
  if (findAccount(username)) { showErr('uname-err'); return; }
  if (!pin) { toast('Please enter a PIN or password.', 'warning'); return; }
  if (pin !== pin2) { showErr('pin2-err'); return; }

  const newAcc = {
    id:       Date.now(),
    username,
    pin,
    patient: {
      firstName:    document.getElementById('su-fname').value.trim(),
      lastName:     document.getElementById('su-lname').value.trim(),
      dob:          document.getElementById('su-dob').value,
      blood:        document.getElementById('su-blood').value,
      condition:    document.getElementById('su-condition').value,
      allergies:    document.getElementById('su-allergies').value,
      setupMode:    suMode,
      capMode:      suCap,
      caregiverName:document.getElementById('su-cg-name')?.value || '',
      caregiverRel: document.getElementById('su-cg-rel')?.value  || '',
      caregiverPhone:document.getElementById('su-cg-phone')?.value || '',
      insurance:    document.getElementById('su-insurance')?.value || '',
      address:      document.getElementById('su-address')?.value  || '',
      idNumber:     'MT-' + Math.floor(100000 + Math.random() * 900000),
      notes:        '',
      insurance:    '',
      address:      '',
      createdAt:    new Date().toISOString()
    }
  };

  const accounts = getAccounts();
  accounts.push(newAcc);
  saveAccounts(accounts);

  CUR = newAcc.id;
  gStore.set('session', CUR);
  toast(`Welcome, ${newAcc.patient.firstName}! Your account has been created.`, 'success');
  launchApp();
}

/* ── Password visibility ── */
function togglePw(inputId, btn) {
  const inp = document.getElementById(inputId);
  inp.type  = inp.type === 'password' ? 'text' : 'password';
  btn.textContent = inp.type === 'password' ? '👁️' : '🙈';
